# --- Server ---
PORT=3000

# Legacy fallback when FRONTEND_URL / API_PUBLIC_URL are not set (single-process local dev).
BASE_URL=http://localhost:3000

# --- Split deploy (Vercel static + Railway API) ---
# FRONTEND_URL = where the HTML lives (PayFast return/cancel redirects).
# API_PUBLIC_URL = where this Express app is reachable (PayFast ITN notify_url).
# Local dev: omit both; BASE_URL is used for everything.
FRONTEND_URL=
API_PUBLIC_URL=

# Example production:
# FRONTEND_URL=https://gigesacpe.vercel.app
# API_PUBLIC_URL=https://your-service.up.railway.app

# CORS: browser origins allowed to call this API (comma-separated).
# Must include your Vercel URL when the site is on Vercel.
CORS_ORIGIN=http://localhost:3000

# Railway / reverse proxy: set so req.ip and ITN IP checks are correct.
# TRUST_PROXY=1

# --- PayFast ---
MERCHANT_ID=
MERCHANT_KEY=
PASSPHRASE=

PAYFAST_SANDBOX=true

PAYFAST_ITEM_AMOUNT=1000.00
PAYFAST_ITEM_NAME=AI Resume Quick-Win Kit

# PAYFAST_ALLOWED_ITN_IPS=
# SKIP_PAYFAST_IP_CHECK=true
