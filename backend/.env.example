# --- Server ---
PORT=3000

# Public base URL (no trailing slash). Used for PayFast return / cancel / notify URLs.
# Local: http://localhost:3000
# Production: https://yourdomain.com
BASE_URL=http://localhost:3000

# CORS: browser origins allowed to call JSON APIs (comma-separated).
CORS_ORIGIN=http://localhost:3000

# Behind nginx / load balancer (for correct client IP on ITN):
# TRUST_PROXY=1

# --- PayFast (sandbox first) ---
# Get these from PayFast → Integration → Merchant credentials (sandbox vs live).
MERCHANT_ID=16283083
MERCHANT_KEY=z3iqm3rwxl7kr
# Passphrase from PayFast security settings (required for signature).
PASSPHRASE=cultivatedText-dev-passphrase4

# true = sandbox (https://sandbox.payfast.co.za/eng/process)
# false = live (https://www.payfast.co.za/eng/process)
PAYFAST_SANDBOX=false

# Must match the checkout amount (two decimals).
PAYFAST_ITEM_AMOUNT=1000.00
PAYFAST_ITEM_NAME=AI Resume Quick-Win Kit

# ITN: PayFast posts to https://YOUR_DOMAIN/api/payfast/itn
# Set the same URL in the PayFast dashboard (Notify URL).

# PayFast production ITN IPs (defaults built-in). Override or extend:
# PAYFAST_ALLOWED_ITN_IPS=197.97.145.144,197.97.145.145

# Local / tunnel testing: PayFast servers cannot POST to localhost — use ngrok etc.
# and set SKIP_PAYFAST_IP_CHECK=true ONLY while testing (never in production).
# SKIP_PAYFAST_IP_CHECK=true
